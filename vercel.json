{
  "buildCommand": "bun install && bun run build",
  "devCommand": "bun run dev",
  "installCommand": "bun install",
  "framework": "vite",
  "outputDirectory": "dist",
  "public": true,
  "regions": ["iad1"],
  "env": {
    "VITE_API_URL": ""
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

